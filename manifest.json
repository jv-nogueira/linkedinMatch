{
  "manifest_version": 3,
  "name": "Match no LinkedIn",
  "description": "Filtra vagas pelas palavras-chave e gera um arquivo em TXT.",
  "version": "1.0",
  "permissions": ["activeTab", "scripting"],
  "host_permissions": ["https://www.linkedin.com/*"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Coincide a descrição"
  },
  "icons": { 
    "48": "icons/automacao.png"
  }
}
